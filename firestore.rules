rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get user role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Helper function to check roles
    function isExamUnit() {
      return isAuthenticated() && getUserRole() == 'exam_unit';
    }
    
    function isHOS() {
      return isAuthenticated() && getUserRole() == 'hos';
    }
    
    function isLecturer() {
      return isAuthenticated() && getUserRole() == 'lecturer';
    }
    
    // Helper function to check if user owns the document
    function isOwner(ownerId) {
      return isAuthenticated() && request.auth.uid == ownerId;
    }
    
    // Helper function to check if user has access to shared file
    function hasSharedAccess(sharedWith) {
      return isAuthenticated() && 
        request.auth.token.email in sharedWith;
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Users can update their own profile (but NOT their role — prevents self-promotion)
      allow update: if isAuthenticated() && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
      
      // Exam Unit can read, update, and delete all users
      allow read, update, delete: if isExamUnit();
      
      // HOS can read all users (needed for dashboard) and update users in their department
      allow read: if isHOS();
      allow update: if isHOS();
      
      // Lecturers can read all users (for collaboration)
      allow read: if isLecturer();
      
      // Allow user creation only for authenticated users creating their own doc with 'pending' role
      allow create: if isAuthenticated() 
        && request.auth.uid == userId
        && request.resource.data.role == 'pending';
    }
    
    // Departments collection
    match /departments/{deptId} {
      // Exam Unit has full access
      allow read, write: if isExamUnit();
      
      // All authenticated users can read departments
      allow read: if isAuthenticated();
    }
    
    // File Versions collection
    match /fileVersions/{versionId} {
      // Authorized users can read versions if they have access to the parent file
      allow read: if isAuthenticated() && (
        isExamUnit() ||
        isHOS() ||
        get(/databases/$(database)/documents/files/$(resource.data.fileId)).data.createdBy == request.auth.uid ||
        request.auth.token.email in get(/databases/$(database)/documents/files/$(resource.data.fileId)).data.sharedWith
      );
      
      // File owners can create versions
      allow create: if isAuthenticated() &&
        get(/databases/$(database)/documents/files/$(request.resource.data.fileId)).data.createdBy == request.auth.uid;
      
      // Exam Unit has full access
      allow read, write: if isExamUnit();
    }
    
    // Feedback collection
    match /feedback/{feedbackId} {
      // Anyone authenticated can read feedback
      allow read: if isAuthenticated();
      
      // HOS and Exam Unit can create feedback
      allow create: if isHOS() || isExamUnit();
      
      // Exam Unit can update/delete feedback
      allow update, delete: if isExamUnit();
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      // Users can read/query their own notifications
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      
      // Users can update their own notifications (mark as read)
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users can delete their own notifications
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // System can create notifications
      allow create: if isAuthenticated();
      
      // Exam Unit can manage all notifications
      allow read, write: if isExamUnit();
    }
    
    // Files collection
    match /files/{fileId} {
      // Lecturers can create files
      allow create: if isAuthenticated() && 
        request.resource.data.createdBy == request.auth.uid;
      
      // Owner can read, update, delete their files (check both createdBy and ownerId)
      allow read, update, delete: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid ||
        resource.data.ownerId == request.auth.uid
      );
      
      // Users with shared access can read (with null safety)
      allow read: if isAuthenticated() && 
        resource.data.sharedWith != null &&
        hasSharedAccess(resource.data.sharedWith);
      
      // HOS can read AND UPDATE files from their department (for approval/rejection)
      allow read, update: if isHOS();
      
      // Exam Unit has full access
      allow read, write: if isExamUnit();
    }
    
    // Audit Logs collection
    match /auditLogs/{logId} {
      // Any authenticated user can create audit logs
      allow create: if isAuthenticated();
      
      // Only Exam Unit can read all audit logs
      allow read: if isExamUnit();
      
      // No one can update or delete audit logs (immutable)
      allow update, delete: if false;
    }
  }
}
